  "rarity_budget_multipliers": {
    "_explanation": "Moltiplicatore relativo applicato al budget statistiche totale per ogni native_rarity. NON è il moltiplicatore HP. È un budget astratto: un 6★ ha ~3.0× del budget di un 1★, distribuito secondo role_stat_bias. Numeri esatti finalizzati in RM1.21-B/C.",
    "1": { "stat_budget_x": 1.00, "max_stars": 4 },
    "2": { "stat_budget_x": 1.30, "max_stars": 6 },
    "3": { "stat_budget_x": 1.65, "max_stars": 8 },
    "4": { "stat_budget_x": 2.05, "max_stars": 10 },
    "5": { "stat_budget_x": 2.50, "max_stars": 12 },
    "6": { "stat_budget_x": 3.00, "max_stars": 15 }
  },

  "rarity_kit_complexity_short": {
    "1": "Kit minimale: basic_attack + 0/1 passive semplice.",
    "2": "Basic + 1 skill semplice + (opzionale) passive semplice.",
    "3": "Basic + 1 skill role-defining + 1 passive ruolo.",
    "4": "Basic + 1 skill + 1 ultimate o passive avanzato (2 mecchaniche correlate).",
    "5": "Kit completo: basic + skill + ultimate + passive con sinergia interna.",
    "6": "Kit iconico: meccanica unica/firma, condizioni avanzate, strong identity."
  },

