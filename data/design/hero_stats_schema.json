{
  "version": "0.2",
  "status": "design_foundation",
  "task_origin": "RM1.21-A",
  "purpose": "Official combat stats schema for the 100 launch heroes + Borea. Design-data only: NOT yet final balance numbers, NOT wired into runtime. Stats listed here describe the canonical combat stat model that future kits will reference.",
  "non_normative_for_runtime": true,
  "runtime_compatibility_notes": [
    "Runtime engine in backend/battle_engine.py currently uses an extended split-damage model (physical_damage/magic_damage, physical_defense/magic_defense) plus legacy aggregates (attack/defense). Both naming conventions are listed under each split stat as 'runtime_keys' for forward-compat.",
    "RM1.21-A does NOT modify backend/battle_engine.py.",
    "Future kits MAY scale on either physical or magic damage; this schema declares both lanes."
  ],

  "stats": [
    {
      "key": "hp",
      "display_name": "HP",
      "description": "Punti vita massimi. Sotto 0 → KO.",
      "type": "int",
      "default": 8000,
      "min": 1,
      "tier": "core",
      "scaling_with_level": true,
      "role_relevance": {
        "Tank": "very_high", "DPS Melee": "mid", "DPS Ranged": "low_mid",
        "Mage AoE": "low_mid", "Assassin / Burst": "low_mid",
        "Support / Buffer": "mid", "Healer": "mid",
        "Control / Debuff": "mid", "Hybrid Special": "mid"
      },
      "runtime_keys": ["hp"]
    },
    {
      "key": "attack",
      "display_name": "ATK",
