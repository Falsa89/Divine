{
  "version": "0.2",
  "status": "design_foundation",
  "task_origin": "RM1.21-A",
  "purpose": "Official skill kit schema for the 100 launch heroes + Borea. Design-data only: NOT yet wired into backend/battle_engine.py. The current runtime exposes 3 element-keyed slots (nad/sad/sp); future kits MAY use the official 4-slot model declared here, OR keep mapping to the legacy slots while sharing the same effect_types vocabulary.",
  "non_normative_for_runtime": true,

  "skill_slots": [
    {
      "id": "basic_attack",
      "display_name": "Attacco Base",
      "description": "Attacco singolo a costo zero, eseguito automaticamente quando la skill non è disponibile o non è scelta.",
      "default_target_type": "single_enemy",
      "cooldown_turns": 0,
      "energy_cost": 0,
      "rarity_required": 1,
      "runtime_legacy_slot": "nad",
      "expected_animation_state": "attack"
    },
    {
      "id": "skill",
      "display_name": "Skill",
      "description": "Skill principale role-defining. Può infliggere danno potenziato e/o applicare un effetto.",
      "default_target_type": "single_enemy",
      "cooldown_turns": 2,
      "energy_cost": 0,
      "rarity_required": 2,
      "runtime_legacy_slot": "sad",
      "expected_animation_state": "skill"
    },
    {
      "id": "ultimate_or_special",
      "display_name": "Ultimate",
      "description": "Skill firma di alto impatto. Tipicamente AoE o burst, gated da rage/cooldown.",
      "default_target_type": "all_enemies",
      "cooldown_turns": 4,
      "energy_cost": 100,
      "rarity_required": 3,
      "runtime_legacy_slot": "sp",
      "expected_animation_state": "skill"
    },
    {
      "id": "passive",
      "display_name": "Passive",
      "description": "Effetto sempre attivo o triggered. Non consuma turno.",
      "default_target_type": "self",
      "cooldown_turns": 0,
      "energy_cost": 0,
      "rarity_required": 1,
      "runtime_legacy_slot": "passive",
      "expected_animation_state": null
    }
  ],

  "skill_field_schema": {
    "id": "string — slug univoco intra-eroe (es. 'phalanx_guard').",
    "name": "string — nome localizzabile (default IT).",
    "description": "string — descrizione player-facing.",
    "type": "enum: basic_attack | skill | ultimate_or_special | passive",
    "target_type": "enum (vedi target_types).",
    "damage_type": "enum: physical | magic | true | none",
    "scaling_stat": "enum: attack | physical_damage | magic_damage | hp_max | healing_power | shield_power | none",
    "multiplier": "float — moltiplicatore applicato a scaling_stat.",
    "cooldown_turns": "int >= 0",
    "energy_cost": "int >= 0",
    "effects": "array di Effect (vedi effect_types)",
    "animation_state": "enum: attack | skill | hit | death | idle",
    "tags": "array<string> liberi (es. 'cleave', 'execute_under_30hp')",
    "unlock_condition": "object opzionale (es. {min_stars: 8})",
    "ignores_taunt": "bool (default false)",
    "ignores_dodge": "bool (default false)"
  },

  "target_types": [
    "self",
    "ally_lowest_hp",
    "ally_highest_atk",
    "all_allies",
    "ally_row",
    "ally_column",
    "single_enemy",
    "enemy_lowest_hp",
    "enemy_highest_atk",
    "enemy_back_row",
    "all_enemies",
    "enemy_row",
    "enemy_column",
    "enemy_area_3x3",
    "random_enemies_n",
    "tank_first_then_nearest"
  ],

  "targeting_rules": {
    "default_single_target": "Se la skill non dichiara target_type esplicito, segue la regola Tank-first → nemico vivo più vicino (Manhattan distance, ties via index). Vedi backend/battle_engine.py:select_default_single_target.",
    "taunt_priority": "Taunt ha priorità massima sulle skill SINGOLO bersaglio, salvo skill con ignores_taunt=true.",
    "aoe_taunt_immune": "Taunt NON intercetta target_type AoE/row/column/all_enemies/multiple/area.",
    "multi_target_runtime_set": [
      "all", "all_enemies", "aoe", "row", "column", "line", "area",
      "multiple", "multi"
    ]
  },

  "effect_types": [
    {
      "id": "damage",
      "label": "Danno",
      "params": ["damage_type", "scaling_stat", "multiplier"],
      "runtime_supported": true
    },
    {
      "id": "heal",
      "label": "Cura",
      "params": ["scaling_stat", "multiplier", "is_hot:false"],
      "runtime_supported": true,
      "runtime_keys_compat": ["heal_per_turn"]
    },
    {
      "id": "shield",
      "label": "Scudo",
      "params": ["scaling_stat:shield_power|hp_max", "multiplier", "duration_turns"],
      "runtime_supported": false,
      "runtime_compat_note": "Da introdurre in fase futura; non rompe runtime corrente."
    },
    {
      "id": "taunt",
      "label": "Provocazione",
      "params": ["duration_turns"],
      "runtime_supported": true,
      "runtime_keys_compat": ["status_effects[type=taunt]"]
    },
    {
      "id": "dot",
      "label": "DoT (Damage over Time)",
      "params": ["damage_type", "damage_per_turn", "duration_turns", "dot_subtype"],
      "dot_subtypes": ["burn", "bleed", "poison"],
      "runtime_supported": true
    },
    {
      "id": "hot",
      "label": "HoT (Heal over Time)",
      "params": ["heal_per_turn", "duration_turns"],
      "runtime_supported": true,
      "runtime_keys_compat": ["heal_per_turn"]
    },
    {
      "id": "buff",
      "label": "Buff",
      "params": ["stat_key", "delta", "is_percent:bool", "duration_turns"],
      "runtime_supported": true
    },
    {
      "id": "debuff",
      "label": "Debuff",
      "params": ["stat_key", "delta", "is_percent:bool", "duration_turns"],
      "runtime_supported": true,
      "runtime_subtypes_legacy": ["weaken", "defense_break", "slow"]
    },
    {
      "id": "control",
      "label": "Controllo (stun/freeze/silence)",
      "params": ["control_subtype", "duration_turns"],
      "control_subtypes": ["stun", "freeze", "silence", "root"],
      "runtime_supported": true,
      "runtime_subtypes_legacy": ["stun", "freeze"]
    },
    {
      "id": "cleanse",
      "label": "Purifica",
      "params": ["target_filter", "removes:debuff|dot|control|all"],
      "runtime_supported": true,
      "runtime_keys_compat": ["purify"]
    },
    {
      "id": "revive",
      "label": "Resurrezione",
      "params": ["hp_percent_after_revive", "max_uses_per_battle"],
      "runtime_supported": false,
      "rarity_min": 5
    },
    {
      "id": "damage_reduction",
      "label": "Riduzione Danni",
      "params": ["delta_percent", "duration_turns", "target"],
      "runtime_supported": true
    },
    {
      "id": "mark",
      "label": "Marchio",
      "params": ["mark_type", "duration_turns", "trigger_effect"],
      "runtime_supported": false
    },
    {
      "id": "execute",
      "label": "Esecuzione (instant kill threshold)",
      "params": ["hp_threshold_percent", "chance"],
      "runtime_supported": true,
      "runtime_keys_compat": ["death_mark.instant_kill_chance"],
      "rarity_min": 5
    },
    {
      "id": "summon_or_proxy",
      "label": "Evocazione/Proxy",
      "params": ["proxy_id", "duration_turns"],
      "runtime_supported": false,
      "rarity_min": 5
    }
  ],

  "role_kit_templates": {
    "Tank": {
      "identity": "Soak damage, redirect threats, protect backline.",
      "stat_priorities": ["hp", "defense", "damage_reduction", "shield_power", "effect_resistance"],
      "common_skills": ["basic_attack single-target", "taunt skill", "shield/damage_reduction passive"],
      "weakness": "Bassa offensiva; vulnerabile a debuff/control prolungati.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy", "scaling_stat": "attack", "multiplier_range": [0.9, 1.1] },
        { "slot": "skill", "effect": "taunt|shield", "duration_turns_range": [1, 3] },
        { "slot": "passive", "effect": "damage_reduction|effect_resistance" }
      ]
    },
    "DPS Melee": {
      "identity": "Front-line single-target burst e sostained damage.",
      "stat_priorities": ["attack", "speed", "crit_rate", "crit_damage", "penetration"],
      "common_skills": ["basic_attack single-target", "skill burst/bleed", "self-buff or rage passive"],
      "weakness": "Bassa difesa; puniti da AoE control.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy", "scaling_stat": "attack", "multiplier_range": [1.0, 1.2] },
        { "slot": "skill", "effect": "damage|dot bleed", "multiplier_range": [1.8, 2.4] },
        { "slot": "passive", "effect": "buff attack on_low_hp|on_kill" }
      ]
    },
    "DPS Ranged": {
      "identity": "Backline marksman: high crit, target prioritization (back row, high atk).",
      "stat_priorities": ["attack", "crit_rate", "crit_damage", "speed", "penetration"],
      "common_skills": ["basic_attack ranged single", "skill multi-shot or focused", "passive crit/mark"],
      "weakness": "HP/DEF basse; vulnerabile a assassin/dive.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy|enemy_back_row", "multiplier_range": [0.95, 1.15] },
        { "slot": "skill", "effect": "damage random_enemies_n|enemy_lowest_hp", "multiplier_range": [1.6, 2.2] },
        { "slot": "passive", "effect": "buff crit_rate|mark on_crit" }
      ]
    },
    "Mage AoE": {
      "identity": "Caster ad area: AoE damage + DoT/debuff elementale.",
      "stat_priorities": ["attack", "effect_accuracy", "speed", "crit_rate"],
      "common_skills": ["basic_attack magic single", "skill AoE damage", "ultimate AoE+DoT/debuff"],
      "weakness": "Lenta cast vs assassin; depends on sticking debuff.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy", "damage_type": "magic" },
        { "slot": "skill", "effect": "damage all_enemies", "multiplier_range": [1.4, 1.8] },
        { "slot": "ultimate_or_special", "effect": "damage+dot all_enemies", "multiplier_range": [3.0, 4.5] }
      ]
    },
    "Assassin / Burst": {
      "identity": "Single-target nuker: alto crit, esecuzione, evasione.",
      "stat_priorities": ["attack", "crit_rate", "crit_damage", "penetration", "speed", "dodge"],
      "common_skills": ["basic_attack quick strike", "skill high burst", "passive execute|stealth|reset"],
      "weakness": "HP basse, perde valore se non finalizza il target.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy", "multiplier_range": [1.0, 1.2] },
        { "slot": "skill", "effect": "damage enemy_lowest_hp|enemy_highest_atk", "multiplier_range": [2.2, 3.0] },
        { "slot": "passive", "effect": "execute hp_threshold_percent<25|crit_damage buff" }
      ]
    },
    "Support / Buffer": {
      "identity": "Team enabler: buff offensive/difensivi, energia, velocità.",
      "stat_priorities": ["speed", "shield_power", "effect_resistance", "hp"],
      "common_skills": ["basic_attack support light", "skill team buff/cleanse", "passive aura"],
      "weakness": "Bassa offensiva diretta; effect_resistance dipendente.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage single_enemy", "multiplier_range": [0.7, 0.9] },
        { "slot": "skill", "effect": "buff all_allies (attack|speed|shield)" },
        { "slot": "passive", "effect": "buff aura (small permanent stat)" }
      ]
    },
    "Healer": {
      "identity": "Pure healing + cleanse + barrier; alta priorità di sopravvivenza.",
      "stat_priorities": ["healing_power", "speed", "hp", "effect_resistance"],
      "common_skills": ["basic_attack light damage|heal", "skill heal single/AoE", "ultimate cleanse|revive (5★+)"],
      "weakness": "Bassa offensiva, depende da team building.",
      "patterns": [
        { "slot": "basic_attack", "effect": "heal ally_lowest_hp", "multiplier_range": [0.8, 1.0] },
        { "slot": "skill", "effect": "heal all_allies|hot all_allies" },
        { "slot": "ultimate_or_special", "effect": "cleanse all_allies|revive ally (5★+)" }
      ]
    },
    "Control / Debuff": {
      "identity": "Disruptor: stun, slow, silence, debuff continuativi.",
      "stat_priorities": ["effect_accuracy", "speed", "hp"],
      "common_skills": ["basic_attack with minor debuff", "skill control (stun/freeze)", "passive disruption"],
      "weakness": "Senza effect_accuracy abbastanza alta i debuff falliscono.",
      "patterns": [
        { "slot": "basic_attack", "effect": "damage+debuff small" },
        { "slot": "skill", "effect": "control single|row (stun|freeze)" },
        { "slot": "passive", "effect": "debuff effect_resistance enemies" }
      ]
    },
    "Hybrid Special": {
      "identity": "Kit unico/iconico, rule-breaking. Riservato a 5★/6★.",
      "stat_priorities": ["depends_on_kit"],
      "common_skills": ["unique mechanic", "conditional effect", "identity-defining passive"],
      "weakness": "Alto skill-floor; richiede team adatto.",
      "patterns": [
        { "slot": "skill", "effect": "any (custom)" },
        { "slot": "passive", "effect": "iconic mechanic" }
      ]
    }
  },

