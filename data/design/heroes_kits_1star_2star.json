{
  "version": "0.1",
  "status": "design_data_only",
  "task_origin": "RM1.21-B",
  "scope": "Official kits for the 8 launch_base 1-star + 12 launch_base 2-star heroes (20 heroes total). Pure schema-data: NOT wired into runtime, NOT imported into DB.",
  "non_normative_for_runtime": true,
  "follows_schema": "data/design/hero_skill_schema.json v0.2 (RM1.21-A)",
  "follows_stats": "data/design/hero_stats_schema.json v0.2 (RM1.21-A)",
  "source_of_truth_roster": "backend/data/character_bible.py",

  "design_rules": {
    "1_star": {
      "philosophy": "Common-unit feeling. Read-at-a-glance: 1 attacco base + 1 passive semplice. Niente ultimate. Niente skill. Niente condizioni avanzate. Niente effect_accuracy/penetration speciali.",
      "active_skills_filled": ["basic_attack"],
      "passive_filled": true,
      "skill_locked": true,
      "ultimate_locked": true,
      "max_effects_per_skill": 1,
      "basic_attack_multiplier_range": [0.90, 1.05],
      "passive_buff_percent_max": 0.10,
      "kit_text_target_lines": 2
    },
    "2_star": {
      "philosophy": "Mythic_archetype semplice ma con identity di ruolo già leggibile: 1 attacco base + 1 skill role-defining + 1 passive coerente. Niente ultimate. Niente sinergie complesse.",
      "active_skills_filled": ["basic_attack", "skill"],
      "passive_filled": true,
      "ultimate_locked": true,
      "max_effects_per_skill": 1,
      "basic_attack_multiplier_range": [0.95, 1.10],
      "skill_multiplier_range_single": [1.40, 1.80],
      "skill_multiplier_range_aoe": [0.90, 1.20],
      "passive_buff_percent_max": 0.12,
      "kit_text_target_lines": 3
    },
    "shared": {
      "preserve_from_character_bible": ["element", "role", "faction", "origin_group"],
      "use_runtime_supported_effects_only": true,
      "allowed_effect_types": [
        "damage", "heal", "hot", "dot",
        "buff", "debuff", "taunt", "control",
        "damage_reduction", "cleanse"
      ],
      "forbidden_effect_types_at_low_rarity": [
        "execute", "revive", "summon_or_proxy", "mark", "shield"
      ],
      "default_targeting": "tank_first_then_nearest",
      "ultimate_slot_value_for_locked_rarities": {
        "slot_locked": true,
        "unlock_at_native_rarity": 3,
        "reason": "RM1.21-A rarity_complexity[1..2].ultimate_allowed = false"
      }
    }
  },

  "stat_profile_legend": {
    "_explanation": "Profili descrittivi non-numerici, allineati a hero_stats_schema role_stat_bias. Numeri esatti in RM1.21-G (balance pass).",
    "scale": ["very_low", "low", "low_mid", "mid", "mid_high", "high", "very_high"]
  },

